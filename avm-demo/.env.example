# 生产环境变量（生产部署时修改！）
# Docker Compose 会读取这些变量，用于 PostgreSQL 和 JWT 配置
POSTGRES_PASSWORD=avm_secure_pwd_change_me
JWT_SECRET=please_change_to_a_long_random_string_in_production
CORS_ORIGIN=http://your-domain.com

# 数据库连接串（Docker Compose 内自动生成，单独部署时使用）
# DATABASE_URL="postgresql://avm:avm_secure_pwd_change_me@postgres:5432/avm?schema=public"
