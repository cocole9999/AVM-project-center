# AVM Backend 环境变量
# 开发模式（本地运行）使用 SQLite:
#   DATABASE_URL="file:./data.db"
# Docker 生产模式使用 PostgreSQL:
#   DATABASE_URL="postgresql://avm:password@localhost:5432/avm?schema=public"

PORT=4000
DATABASE_URL="file:./data.db"
NODE_ENV=development

# LLM 配置（可选）
# LLM_PROVIDER=mock
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# 飞书 OAuth（可选）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_REDIRECT_URI=http://localhost:5173/sso/feishu/callback
